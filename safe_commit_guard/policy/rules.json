{
  "secret_patterns": [
    "AKIA[0-9A-Z]{16}",
    "-----BEGIN (RSA|EC|OPENSSH|DSA|PRIVATE) KEY-----",
    "(?i)(api[_-]?key|secret|password|token)\\s*[:=]\\s*[\"']?[A-Za-z0-9_\\-\\./+=]{8,}",
    "gh[pousr]_[A-Za-z0-9]{20,}",
    "xox[baprs]-[A-Za-z0-9-]{10,}"
  ],
  "commit_message_patterns": [
    "AKIA[0-9A-Z]{16}",
    "gh[pousr]_[A-Za-z0-9]{20,}",
    "(?i)(password|token|secret)\\s*[:=]\\s*[^\\s]+",
    "(?i)https?://(10\\.|172\\.(1[6-9]|2[0-9]|3[0-1])\\.|192\\.168\\.)\\S*"
  ],
  "risky_extensions": [".env", ".pem", ".key", ".p12", ".pfx", ".crt"],
  "risky_filenames": ["id_rsa", "credentials.json", "secrets.yml"],
  "entropy_threshold": 4.3,
  "min_entropy_length": 24,
  "max_added_lines": 800,
  "confirm_ttl_seconds": 180
}
